import java.util.*;

public class NQueens {

    static int x[] = new int[10];

    // Check if safe
    public static boolean place(int k, int i) {
        for (int j = 1; j < k; j++) {
            if (x[j] == i || Math.abs(x[j] - i) == Math.abs(j - k)) {
                return false;
            }
        }
        return true;
    }

    // Backtracking function
    public static void queen(int k, int n) {
        for (int i = 1; i <= n; i++) {
            if (place(k, i)) {
                x[k] = i;

                if (k == n) {
                    write(n);
                } else {
                    queen(k + 1, n);
                }
            }
        }
    }

    // Print board like your image
    public static void write(int n) {
        System.out.println();

        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= n; j++) {
                if (x[i] == j)
                    System.out.print(" Q ");
                else
                    System.out.print(" - ");
            }
            System.out.println();
        }

        System.out.println("-------------------");
    }

    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter no. of queens to place:");
        int n = sc.nextInt();

        queen(1, n);
    }
}                                                   
