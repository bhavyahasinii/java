import java.util.*;

class MinHeap {
    int[] a;
    int size = 0;

    MinHeap(int cap) {
        a = new int[cap + 1];
    }

    void insert(int x) {
        int i = ++size;
        while (i > 1 && x < a[i / 2]) {
            a[i] = a[i / 2];
            i /= 2;
        }
        a[i] = x;
    }

    int deleteMin() {
        if (size == 0) return -1;

        int min = a[1], x = a[size--], i = 1;

        while (2 * i <= size) {
            int j = 2 * i;
            if (j < size && a[j] > a[j + 1]) j++;
            if (x <= a[j]) break;
            a[i] = a[j];
            i = j;
        }
        a[i] = x;

        return min;
    }

    void display() {
        for (int i = 1; i <= size; i++)
            System.out.print(a[i] + " ");
        System.out.println();
    }
}

public class Main {
    public static void main(String[] args) {
        MinHeap h = new MinHeap(10);

        h.insert(50);
        h.insert(30);
        h.insert(40);
        h.insert(10);

        h.display();

        System.out.println("Deleted: " + h.deleteMin());
        h.display();
    }
}                    
