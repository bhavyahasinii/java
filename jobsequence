import java.util.*;

class Job {
    int id, d, p;
    Job(int id, int d, int p) {
        this.id = id; this.d = d; this.p = p;
    }
}

public class Main {
    public static void main(String[] args) {
        Job[] j = {
            new Job(1,2,100),
            new Job(2,1,19),
            new Job(3,2,27),
            new Job(4,1,25),
            new Job(5,3,15)
        };

        Arrays.sort(j, (a,b) -> b.p - a.p);

        int[] slot = new int[4]; 
        Arrays.fill(slot, -1);

        int profit = 0;

        for (Job x : j) {
            for (int k = x.d; k > 0; k--) {
                if (slot[k] == -1) {
                    slot[k] = x.id;
                    profit += x.p;
                    break;
                }
            }
        }

        for (int i = 1; i <= 3; i++)
            if (slot[i] != -1)
                System.out.print("J" + slot[i] + " ");

        System.out.println("\nProfit: " + profit);
    }
}                                                                                                                                                                                            
